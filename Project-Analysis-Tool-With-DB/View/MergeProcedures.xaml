<Window x:Class="SpAnalyzerTool.View.MergeProcedures"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpAnalyzerTool.View"
        mc:Ignorable="d"
        Title="📂 .bak دمج الاجراءات من ملفي"
        ResizeMode="CanMinimize"
        WindowState="Maximized"
        
        WindowStartupLocation="CenterScreen"
       Foreground="{StaticResource TextBrush}"
       Background="{StaticResource BackgroundBrush}"
       Height="750" Width="850">

    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>

        <Style TargetType="TextBlock" BasedOn="{StaticResource HeaderTextBlock}">
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <local:SourceToColorConverter x:Key="SourceColorConverter"/>
        <local:MergeStatusToBrushConverter x:Key="StatusBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </Window.Resources>
    
    <ScrollViewer>
        <StackPanel Margin="20" Orientation="Vertical" >

            <!-- اختيار ملفات الباك -->
            <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Center">
                <Button Content="استعراض" Margin="10,0" Width="80" Click="BrowseBak1_Click"/>
                <TextBox x:Name="txtBak1" Width="300" Height="37"/>
                <TextBlock Text="🔍 الملف الاول  " Width="160" FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0"/>
          
                <Button Content="استعراض" Margin="10,0" Width="80" Click="BrowseBak2_Click"/>
                <TextBox x:Name="txtBak2" Width="400" Height="37"/>
                <TextBlock Text="🔍 الملف الثاني" Width="160" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- زر الدمج -->
            <Button x:Name="btnAnalyze"
                 Content="🔄 تحليل ودمج الإجراءات"
                 Width="220" Height="40" Margin="0 10"
                 HorizontalAlignment="Center"
                 Click="AnalyzeAndMerge_Click"/>

            <!-- عرض الإجراءات من كل bak -->
            <Grid Margin="10" x:Name="grdBakResult" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="📁 الملف الاول" Grid.Column="0" Margin="5">
                    <ListBox x:Name="ListBoxLeft" Height="200" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" 
                               Background="{Binding Converter={StaticResource SourceColorConverter}}"
                               Padding="5" Margin="2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <!-- من bak 2 -->
                <GroupBox Header="📁 الملف الثاني" Grid.Column="1" Margin="5">
                    <ListBox x:Name="ListBoxRight" Height="200" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" 
                               Background="{Binding Converter={StaticResource SourceColorConverter}}"
                               Padding="5" Margin="2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
            </Grid>

            <!-- الإجراءات المدموجة -->
            <GroupBox Header="🧪 الإجراءات بعد الدمج" Grid.Column="2" Margin="5" Visibility="Collapsed" x:Name="grbResult">
                <StackPanel>
                    <!-- مفتاح الألوان -->
                    <WrapPanel Margin="6,2,6,8">
                        <TextBlock Text="● الأول فقط" Foreground="#6BB0FF" Margin="0,0,14,0"/>
                        <TextBlock Text="● الثاني فقط" Foreground="#34D399" Margin="0,0,14,0"/>
                        <TextBlock Text="● متطابق" Foreground="#9AA0B4" Margin="0,0,14,0"/>
                        <TextBlock Text="● تعارض" Foreground="#FBBF24"/>
                    </WrapPanel>

                    <ListBox x:Name="MergedList" Height="220" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,3" Margin="1" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsIncluded}" VerticalAlignment="Center"
                                                  Margin="0,0,8,0" ToolTip="تضمين في السكربت الناتج"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   MinWidth="240" FontFamily="Consolas"/>
                                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                                                   Margin="10,0,0,0" FontWeight="Bold"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusBrushConverter}}"/>
                                        <CheckBox Content="اعتمد الملف الثاني" VerticalAlignment="Center" Margin="12,0,0,0"
                                                  IsChecked="{Binding UseSecond}"
                                                  Visibility="{Binding IsConflict, Converter={StaticResource BoolToVis}}"
                                                  ToolTip="عند التعارض: اعتمد نسخة الملف الثاني بدل الأول"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Right" Visibility="Collapsed" x:Name="stNewBakName">
              
            <!-- زر الحفظ -->
            <Button Content="💾 حفظ السكربت (.sql)" x:Name="btnSave" Visibility="Collapsed"
                 Width="300" Height="40" Margin="10,0"
                 HorizontalAlignment="Center"
                 Click="SaveMergedProcedures_Click"/>


                <TextBox x:Name="txtOutputBakName" Width="300" Text="MergedProcedures" Height="37"/>
                <TextBlock Text="📦 : اسم ملف السكربت (.sql)" Width="200" Margin="5,10,0,0"  />

            </StackPanel>

            <!-- ملخص -->
            <TextBlock x:Name="txtSummary" HorizontalAlignment="Center" FontSize="14" Foreground="{StaticResource TextMutedBrush}" Margin="0,10"/>
       
        </StackPanel>
    </ScrollViewer>


</Window>
